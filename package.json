{
  "name": "@banou/stub",
  "version": "0.0.15",
  "type": "module",
  "license": "MIT",
  "main": "build/index.js",
  "keywords": [
    "fkn",
    "fkn-type:app"
  ],
  "files": [
    "build"
  ],
  "devDependencies": {
    "@eddeee888/gcg-typescript-resolver-files": "^0.12.1",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-document-nodes": "^4.0.16",
    "@graphql-codegen/typescript-resolvers": "^4.5.1",
    "@graphql-codegen/urql-introspection": "^3.0.1",
    "@playwright/test": "^1.54.2",
    "@prisma/client": "^6.13.0",
    "@prisma/driver-adapter-utils": "^6.13.0",
    "@prisma/internals": "^6.14.0",
    "@types/chai": "^5.2.2",
    "@types/chai-as-promised": "^8.0.2",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "chai": "^5.2.1",
    "chai-as-promised": "^8.0.1",
    "chai-shallow-deep-equal": "^1.4.6",
    "drizzle-kit": "^0.31.4",
    "playwright": "^1.54.2",
    "prisma": "^6.13.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "vite-plugin-node-polyfills": "^0.24.0"
  },
  "scripts": {
    "dev": "npm run build-prisma && vite --port 4560",
    "test-server": "vite --port 7357 --config vite.test.config.ts",
    "build": "npm run build-prisma && npm run gql-generate && vite build",
    "build-test": "vite build --config vite.test.config.ts",
    "build-test-watch": "vite build --config vite.test.config.ts --watch",
    "test": "npm run build-prisma && npm run build-test && npx playwright test",
    "test-watch": "set PWTEST_WATCH=1 & npx playwright test",
    "test-watch-headful": "npx playwright test --ui",
    "gql-generate": "graphql-codegen --config codegen.ts",
    "build-prisma": "npm run migrate-prisma && npm run generate-prisma && npm run generate-gql-prisma",
    "generate-prisma": "prisma migrate reset -f && npx prisma migrate dev && prisma generate --sql",
    "migrate-prisma": "shx mkdir -p prisma/migrations/0_init && prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0_init/migration.sql",
    "generate-gql-prisma": "node --experimental-strip-types ./prisma/generate-gql-schema.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fkn/lib": "^0.2.1",
    "@graphql-yoga/plugin-defer-stream": "^3.15.1",
    "@urql/devtools": "^2.0.3",
    "@urql/exchange-graphcache": "^8.1.0",
    "graphql-yoga": "^5.15.1",
    "lucide-react": "^0.536.0",
    "osra": "^0.1.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-player": "^3.3.1",
    "temporal-polyfill": "^0.3.0",
    "urql": "^4.2.2",
    "wa-sqlite": "^1.0.0",
    "wouter": "^3.7.1"
  }
}
