generator client {
  provider               = "prisma-client"
  previewFeatures        = ["queryCompiler", "driverAdapters", "typedSql"]
  output                 = "../src/worker/prisma/generated"
  runtime                = "workerd"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Media {
  /// Uri consists of the `origin` and `id` fields in the format `origin:id`
  uri    String  @id @unique
  /// String that is used to target a specific origin, e.g `google` or `yt` for youtube
  origin String
  /// An id that references a specific resource within the origin space
  id     String
  /// An url to the media resource
  url    String?

  aggregated Boolean? @default(false)

  /// Links to external/other resources related to itself
  handles  Media[] @relation("mediaHandles")
  handleOf Media[] @relation("mediaHandles")

  titles            MediaTitle[]
  type              MediaType?
  status            MediaStatus?
  shortDescriptions MediaShortDescription[]
  descriptions      MediaDescription[]

  trailers      MediaTrailer[]
  covers        MediaCover[]
  banners       MediaBanner[]
  externalLinks String?

  averageScore Int?
  popularity   Int?

  startDate    DateTime?
  endDate      DateTime?
  isAdult      Boolean?
  episodeCount Int?

  episodes Episode[]

  @@unique([origin, id])
  @@index([uri])
  @@index([origin, id])
  @@map("media")
}

model MediaTitle {
  language String
  title    String
  Media    Media?  @relation(fields: [mediaUri], references: [uri])
  mediaUri String?

  @@id(name: "id", fields: [language, title])
  @@map("mediaTitle")
}

model MediaShortDescription {
  language         String
  shortDescription String
  Media            Media?  @relation(fields: [mediaUri], references: [uri])
  mediaUri         String?

  @@id(name: "id", fields: [language, shortDescription])
  @@map("mediaShortDescription")
}

model MediaDescription {
  language    String
  description String
  Media       Media?  @relation(fields: [mediaUri], references: [uri])
  mediaUri    String?

  @@id(name: "id", fields: [language, description])
  @@map("mediaDescription")
}

model MediaTrailer {
  /// Uri consists of the `origin` and `id` fields in the format `origin:id`
  uri    String  @id @unique
  /// String that is used to target a specific origin, e.g `google` or `yt` for youtube
  origin String
  /// An id that references a specific resource within the origin space
  id     String
  /// An url to the media resource
  url    String?

  language  String
  thumbnail String?

  Media    Media?  @relation(fields: [mediaUri], references: [uri])
  /// gql-omit
  mediaUri String?

  @@map("mediaTrailer")
}

model MediaCover {
  language String
  url      String
  height   Int?
  width    Int?
  /// Average #hex color of cover image
  color    String?

  Media    Media?  @relation(fields: [mediaUri], references: [uri])
  /// gql-omit
  mediaUri String?

  @@id(name: "id", fields: [language, url])
  @@map("mediaCover")
}

model MediaBanner {
  language String
  url      String
  height   Int?
  width    Int?
  /// Average #hex color of cover image
  color    String?

  Media    Media?  @relation(fields: [mediaUri], references: [uri])
  /// gql-omit
  mediaUri String?

  @@id(name: "id", fields: [language, url])
  @@map("mediaBanner")
}

enum MediaType {
  TV
  MOVIE
  ANIME
  /// Special episodes that have been included in DVD/Blu-ray releases, picture dramas, pilots, etc
  SPECIAL
  /// (Original Video Animation) Anime that have been released directly on
  /// DVD/Blu-ray without originally going through a theatrical release or
  /// television broadcast
  OVA
  /// (Original Net Animation) Anime that have been originally released online or are only available through streaming services.
  ONA
  /// Live action media such as movies or TV show
  LIVE_ACTION
}

enum MediaStatus {
  /// Has completed and is no longer being released
  FINISHED

  /// Currently releasing
  RELEASING

  /// To be released at a later date
  NOT_YET_RELEASED

  /// Ended before the work could be finished
  CANCELLED

  /// Is currently paused from releasing and will resume at a later date
  HIATUS
}

model Episode {
  /// Uri consists of the `origin` and `id` fields in the format `origin:id`
  uri    String  @id @unique
  /// String that is used to target a specific origin, e.g `google` or `yt` for youtube
  origin String
  /// An id that references a specific resource within the origin space
  id     String
  /// An url to the media resource
  url    String?

  aggregated Boolean @default(false)

  titles            EpisodeTitle[]
  shortDescriptions EpisodeShortDescription[]
  descriptions      EpisodeDescription[]

  releaseDate    DateTime?
  relativeNumber Int?
  absoluteNumber Int?
  thumbnails     EpisodeThumbnail[]

  playbackSources PlaybackSource[]

  Media    Media?  @relation(fields: [mediaUri], references: [uri])
  /// gql-omit
  mediaUri String?

  @@unique([origin, id])
  @@index([uri])
  @@index([origin, id])
  @@map("episode")
}

model EpisodeTitle {
  language   String
  title      String
  Episode    Episode? @relation(fields: [episodeUri], references: [uri])
  episodeUri String?

  @@id(name: "id", fields: [language, title])
  @@map("episodeTitle")
}

model EpisodeShortDescription {
  language         String
  shortDescription String
  Episode          Episode? @relation(fields: [episodeUri], references: [uri])
  episodeUri       String?

  @@id(name: "id", fields: [language, shortDescription])
  @@map("episodeShortDescription")
}

model EpisodeDescription {
  language    String
  description String
  Episode     Episode? @relation(fields: [episodeUri], references: [uri])
  episodeUri  String?

  @@id(name: "id", fields: [language, description])
  @@map("episodeDescription")
}

model EpisodeThumbnail {
  language String
  url      String
  height   Int?
  width    Int?
  /// Average #hex color of cover image
  color    String?

  Episode    Episode? @relation(fields: [episodeUri], references: [uri])
  /// gql-omit
  episodeUri String?

  @@id(name: "id", fields: [language, url])
  @@map("episodeThumbnail")
}

model PlaybackSource {
  /// Uri consists of the `origin` and `id` fields in the format `origin:id`
  uri    String  @id @unique
  /// String that is used to target a specific origin, e.g `google` or `yt` for youtube
  origin String
  /// An id that references a specific resource within the origin space
  id     String
  /// An url to the media resource
  url    String?

  type PlaybackSourceType

  /// JSON data for custom players
  data Json?

  Episode    Episode? @relation(fields: [episodeUri], references: [uri])
  /// gql-omit
  episodeUri String?

  @@unique([origin, id])
  @@index([uri])
  @@index([origin, id])
  @@map("playbackSource")
}

enum PlaybackSourceType {
  IFRAME
  CUSTOM
  OTHER
}
